            "name": "perPage",
            "in": "query",
            "required": true,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "sorting.orderDirection",
            "in": "query",
            "required": true,
            "type": "string",
            "enum": [
              "ORDER_DIRECTION_UNSPECIFIED",
              "ASC",
              "DESC"
            ],
            "default": "ORDER_DIRECTION_UNSPECIFIED"
          },
          {
            "name": "sorting.orderBy",
            "in": "query",
            "required": true,
            "type": "string",
            "enum": [
              "ORDER_BY_UNSPECIFIED",
              "BARCODES_DAMAGE_AMOUNT",
              "CREATED_AT"
            ],
            "default": "ORDER_BY_UNSPECIFIED"
          },
          {
            "name": "status",
            "in": "query",
            "required": true,
            "type": "string",
            "enum": [
              "CASE_STATUS_UNSPECIFIED",
              "NEW",
              "DOCUMENT_GATHERING",
              "WAITING_FOR_VUD",
              "JUDICIAL_PROCEEDINGS",
              "COMPLETED"
            ],
            "default": "CASE_STATUS_UNSPECIFIED"
          },
          {
            "name": "filter.priority",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "TASK_PRIORITY_UNSPECIFIED",
              "LOW",
              "HIGH"
            ],
            "default": "TASK_PRIORITY_UNSPECIFIED"
          },
          {
            "name": "filter.officeId",
