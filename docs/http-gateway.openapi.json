            "enum": [
              "VIOLATOR_TYPE_UNSPECIFIED",
              "EMPLOYEE",
              "CLIENT"
            ],
            "default": "VIOLATOR_TYPE_UNSPECIFIED"
          },
          {
            "name": "filter.kusp",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter.ud",
            "in": "query",
            "required": false,
            "type": "string"
